# ─────────────────────────────────────────────
# BizHub AI — Environment Variables (MySQL version)
# Copy file này thành .env rồi điền thông tin vào
# KHÔNG commit file .env lên git!
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000
SITE_URL=https://bizhub.edunow.today
ALLOWED_ORIGIN=https://bizhub.edunow.today

# ── MySQL Database ─────────────────────────────
# Lấy thông tin trong Aaanel > Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bizhub
DB_USER=bizhub_user
DB_PASSWORD=ĐIỀN_MẬT_KHẨU_DATABASE_VÀO_ĐÂY

# ── AI Providers ──────────────────────────────
# Chỉ điền provider nào bạn muốn dùng

ANTHROPIC_API_KEY=
OPENAI_API_KEY=ĐIỀN_KEY_OPENAI_VÀO_ĐÂY
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=ĐIỀN_KEY_OPENROUTER_VÀO_ĐÂY
OLLAMA_BASE_URL=
